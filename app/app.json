{
  "expo": {
    "name": "dogdex",
    "slug": "dogdex",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dogdex",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mulleresposito.dogdex",
      "adaptiveIcon": {
        "backgroundColor": "#8DB0C2",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "kotlinVersion": "2.0.21",
            "extraGradleProperties": [
              "org.gradle.jvmargs=-Xmx2048m -XX:MaxMetaspaceSize=512m",
              "android.enablePngCrunchInReleaseBuilds=false"
            ]
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir DogDex a acessar sua câmera"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/android-icon-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#8DB0C2"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29768979-b2fc-4ed4-b806-c7b6e5e3fbff"
      }
    }
  }
}
