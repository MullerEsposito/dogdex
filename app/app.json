{
  "expo": {
    "name": "dogdex",
    "slug": "dogdex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dogdex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mulleresposito.dogdex",
      "adaptiveIcon": {
        "backgroundColor": "#8DB0C2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir DogDex a acessar sua câmera"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-v2.png",
          "imageWidth": 450,
          "resizeMode": "contain",
          "backgroundColor": "#DC0A2D",
          "dark": {
            "backgroundColor": "#8B0000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29768979-b2fc-4ed4-b806-c7b6e5e3fbff"
      }
    }
  }
}
