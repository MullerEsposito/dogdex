{
  "name": "dogdex",
  "main": "index.js",
  "version": "0.3.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild:dev": "cross-env APP_ENV=development npx expo prebuild",
    "build:android:dev": "node scripts/build-dev.js",
    "start:dev": "cross-env APP_ENV=development npx expo start --dev-client",
    "prebuild:prod": "cross-env APP_ENV=production npx expo prebuild",
    "build:android:prod": "cross-env APP_ENV=production npx expo prebuild && cd android && .\\gradlew.bat assembleRelease",
    "bundle:android:prod": "cross-env APP_ENV=production npx expo prebuild && cd android && .\\gradlew.bat bundleRelease",
    "test": "jest"
  },
  "dependencies": {
    "@dogdex/shared": "*",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.104.0",
    "expo": "~55.0.12",
    "expo-auth-session": "~55.0.14",
    "expo-av": "^16.0.8",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.12",
    "expo-camera": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.11",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.23",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.13",
    "expo-image": "~55.0.8",
    "expo-image-picker": "^55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-location": "~55.1.7",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.13",
    "expo-speech": "~55.0.12",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.14",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-copilot": "^3.3.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.1.7",
    "babel-preset-expo": "~55.0.8",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
