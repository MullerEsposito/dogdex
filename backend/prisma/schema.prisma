// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// We use Supabase Postgres for production and development.
datasource db {
  provider = "postgresql"
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password           String?    // Hashed (Opcional para login social)
  name               String?
  avatarUrl          String?
  socialProvider     String?    // ex: 'google', 'apple'
  isSocial           Boolean    @default(false)
  resetToken         String?    @unique
  resetTokenExpires  DateTime?
  entries            DogEntry[]
  adoptionPoints     AdoptionPoint[] @relation("PointCreator")
  adopterChatSessions ChatSession[]  @relation("AdopterChatSessions")
  creatorChatSessions ChatSession[]  @relation("CreatorChatSessions")
  messages           Message[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model DogEntry {
  id           String   @id @default(uuid()) // UUID instead of local timestamp IDs
  localId      String?  // Map to local AsyncStorage ID for sync resolution
  breedName    String
  confidence   Float
  locationAddr String
  imageUri     String   // This will be the Supabase public URL
  status       String   @default("synced") // e.g., "synced", "pending", "deleted"
  timestamp    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
}

model AdoptionPoint {
  id           String        @id @default(uuid())
  name         String
  description  String?
  latitude     Float
  longitude    Float
  address      String?
  contactPhone String?       // New field for WhatsApp contact
  creatorId    String
  creator      User          @relation("PointCreator", fields: [creatorId], references: [id])
  dogs         AdoptionDog[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AdoptionDog {
  id              String        @id @default(uuid())
  name            String
  breedName       String
  age             String?
  description     String?
  imageUri        String
  status          String        @default("available") // e.g., "available", "adopted"
  adoptionPointId String
  adoptionPoint   AdoptionPoint @relation(fields: [adoptionPointId], references: [id])
  creatorId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ChatSession {
  id              String        @id @default(uuid())
  adopterId       String
  adopter         User          @relation("AdopterChatSessions", fields: [adopterId], references: [id])
  creatorId       String
  creator         User          @relation("CreatorChatSessions", fields: [creatorId], references: [id])
  adoptionPointId String
  adoptionPoint   AdoptionPoint @relation(fields: [adoptionPointId], references: [id])
  messages        Message[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([adopterId, adoptionPointId])
}

model Message {
  id            String      @id @default(uuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id])
  content       String
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

