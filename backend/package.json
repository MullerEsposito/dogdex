{
  "name": "dogdex-backend",
  "version": "0.4.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- tsx --watch src/server.ts",
    "build": "dotenv -e .env.production -- npx prisma generate ; tsc && mkdir -p dist/model && cp -r src/shared/model/dogdex_model_tfjs dist/model/ || true",
    "start": "node dist/server.js",
    "test": "dotenv -e .env.development -- jest --runInBand",
    "test:auth": "dotenv -e .env.development -- jest --testPathPatterns=auth.integration",
    "test:sync": "dotenv -e .env.development -- jest --testPathPatterns=sync.integration",
    "db:push": "dotenv -e .env.development -- prisma db push",
    "db:studio": "dotenv -e .env.development -- prisma studio",
    "db:clone": "tsx src/scripts/cloneDb.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@dogdex/shared": "*",
    "@google-cloud/vision": "^5.3.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tensorflow/tfjs-node": "4.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fs": "^0.0.1-security",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
